# rename this file .env and start configuring


# general configuration
LANGUAGE_CODE="en-us"
TIME_ZONE="UTC"


# webapp internals
SECRET_KEY=xxx
DEBUG=True
ALLOWED_HOSTS=.localhost, 127.0.0.1
DB_NAME=db.sqlite3


# telegram options
TELEGRAM_API_ID=123
TELEGRAM_API_HASH=xxx
TELEGRAM_PHONE_NUMBER=+123
TELEGRAM_CRAWLER_GRACE_TIME=1
TELEGRAM_CRAWLER_DOWNLOAD_IMAGES=False
TELEGRAM_CRAWLER_DOWNLOAD_VIDEO=False
TELEGRAM_CRAWLER_MESSAGES_LIMIT_PER_CHANNEL=100  # Set to None to disable the limit.
TELEGRAM_CONNECTION_RETRIES=10   # How many times Telethon retries a failed connection before giving up.
TELEGRAM_RETRY_DELAY=5           # Seconds to wait between connection retry attempts.
TELEGRAM_FLOOD_SLEEP_THRESHOLD=60  # Telethon auto-sleeps on FloodWait errors up to this many seconds; raises an exception above this threshold.


# ForceAtlas2 options
FA2_ITERATIONS=20000


# network options
REVERSED_EDGES=True
NETWORK_MEASURES=PAGERANK  # comma-separated list of: PAGERANK, HITSHUB, HITSAUTH, BETWEENNESS, INDEGCENTRALITY
CHANNEL_TYPES=CHANNEL  # comma-separated list of: CHANNEL (broadcast channels), GROUP (supergroups and gigagroups), USER (user accounts and bots)


# communities options
COMMUNITIES_STRATEGY=ORGANIZATION, LEIDEN, LOUVAIN, KCORE, INFOMAP  # comma-separated list of: ORGANIZATION, LEIDEN, LOUVAIN, KCORE, INFOMAP
COMMUNITIES_PALETTE=ORGANIZATION  # ORGANIZATION or any https://python-graph-gallery.com/color-palette-finder/ palette, mind letter case


# drawing options
DRAW_DEAD_LEAVES=False
DEAD_LEAVES_COLOR=#596a64
LAYOUT=HORIZONTAL  # HORIZONTAL or VERTICAL — rotates the graph 90° when its aspect ratio doesn't match
